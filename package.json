{
  "name": "monitor-14-24-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:int": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --reporter=default",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config oxlint.config.json . && prettier --check .",
    "lint:fix": "oxlint --config oxlint.config.json --fix . && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "vitest bench",
    "bench:browser": "echo \"Tier 2 placeholder — requires Playwright install\"",
    "build:ci": "vite build --mode ci"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.20.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.10",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "4.1.10"
  }
}
