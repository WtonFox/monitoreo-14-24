{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "jsx-a11y"],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true,
    "vitest": true
  },
  "settings": {
    "react": {
      "version": "19.2.7"
    }
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "coverage/",
    ".codegraph/",
    ".atl/"
  ],
  "rules": {
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "warn"
  }
}
