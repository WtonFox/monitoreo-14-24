# VITE_BASE_PATH — Base path for subdirectory deployment
# Used when serving the app from a sub-path (e.g., .NET integration).
# Example: /monitoreo/ — must start and end with /
# Default: / (root-relative)
# VITE_BASE_PATH=/monitoreo/

# GEMINI_API_KEY — Optional API key for AI-powered features
# Used for Gemini AI integration (Chatbot, analysis features).
# Not required for basic operation.
# GEMINI_API_KEY=your-gemini-api-key
